# --- XMTP identity (generate with: npm run gen:keys) ---
# Agent's wallet private key (0x-prefixed). DO NOT commit the real value.
WALLET_KEY=0x...
# Local DB encryption key (32-byte hex). DO NOT commit the real value.
ENCRYPTION_KEY=...
# XMTP network: "dev" for testing via xmtp.chat, "production" for Base App.
XMTP_ENV=dev

# --- Anthropic (intervention wording only) ---
ANTHROPIC_API_KEY=sk-ant-...
# Cheap model for scale (~$16/mo for 100 users). Model name lives in env per spec.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Base chain RPC (Alchemy / CDP free tier) ---
# Defaults to the public Base RPC if unset; set this for real usage.
BASE_RPC_URL=https://mainnet.base.org

# --- Watcher tuning ---
# How often to poll wallets for new trades, in milliseconds.
POLL_INTERVAL_MS=60000
# Hour (server-local, 0-23) to send the single daily evening check-in.
DAILY_CHECKIN_HOUR=20
